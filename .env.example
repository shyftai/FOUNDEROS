# FOUNDER:OS — Environment Variables
# Copy this file to .env and fill in your values

# ─── Supabase (optional — for team mode) ───
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ─── Slack (optional — for notifications) ───
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=

# ─── Connected OS framework paths (auto-detected, override if needed) ───
# GTMOS_PATH=/c/Antigravity/GTMOS
# CONTENTOS_PATH=/c/Antigravity/CONTENTOS
# FINANCEOS_PATH=/c/Antigravity/FINANCEOS
# HROS_PATH=/c/Antigravity/HROS
# INVESTOROS_PATH=/c/Antigravity/INVESTOROS
# COMMUNITYOS_PATH=/c/Antigravity/COMMUNITYOS

# ─── Calendar integration (optional) ───
GOOGLE_CALENDAR_API_KEY=
CALENDLY_API_KEY=

# ─── AI/Research (optional) ───
EXA_API_KEY=
FIRECRAWL_API_KEY=
